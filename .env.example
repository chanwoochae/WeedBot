# Discord
DISCORD_BOT_TOKEN=

# Ollama (MacBook) — 맥북 오프라인 시 Gemini로 자동 폴백
# Cloudflare Tunnel 사용 시: https://xxxx.trycloudflare.com
# 로컬 IP 직접 사용 시: http://192.168.x.x:11434
OLLAMA_BASE_URL=http://YOUR_MACBOOK_IP:11434
OLLAMA_MODEL=gemma4:31b
OLLAMA_TIMEOUT_MS=600000  # 10분

# Gemini (폴백)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Supabase (히스토리)
SUPABASE_URL=
SUPABASE_KEY=

# 히스토리 윈도우 크기
HISTORY_WINDOW=20
