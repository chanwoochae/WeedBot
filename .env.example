# Discord
DISCORD_BOT_TOKEN=

# Ollama (MacBook) — autossh 역방향 터널로 연결
# autossh -M 0 -R 11434:localhost:11434 opc@ORACLE_IP -N -i ~/.ssh/id_ed25519
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:31b
OLLAMA_TIMEOUT_MS=300000

# Gemini (폴백 / 심층 분석)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_MODEL_PRO=gemini-3.1-pro-preview

# Supabase (히스토리)
SUPABASE_URL=
SUPABASE_KEY=

# 히스토리 윈도우 크기
HISTORY_WINDOW=20
